      "source": [
        "from sklearn.metrics import confusion_matrix, classification_report, roc_auc_score\n",
        "\n",
        "def evaluate_model(model, X_test, y_test, model_name=\"Model\"):\n",
        "\n",
        "    # Predict\n",
        "    y_pred = model.predict(X_test)\n",
        "\n",
        "    # Calculate metrics\n",
        "    report = classification_report(y_test, y_pred, output_dict=True)\n",
        "    cm = confusion_matrix(y_test, y_pred)\n",
        "    proba = model.predict_proba(X_test)[:, 1]\n",
        "\n",
        "    metrics = {\n",
        "        'model_name': model_name,\n",
        "        # 'accuracy': report['accuracy'], lets ignore the accuracy\n",
        "\n",
        "        'precision_1': round(report['1.0']['precision'],3),\n",
        "        'recall_1': round(report['1.0']['recall'],3),\n",
        "        'f1_1': round(report['1.0']['f1-score'],3),\n",
        "        \"roc_auc\": round(roc_auc_score(y_test, proba),3)\n",
        "        # 'confusion_matrix': cm.tolist() # Convert numpy array to list for easier storage\n",
        "    }\n",
        "\n",
        "\n",
        "    return metrics\n"
      ]
    },
